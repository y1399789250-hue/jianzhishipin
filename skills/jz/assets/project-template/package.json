{
  "name": "jz-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts PaperCutVideo out/final.mp4",
    "validate": "node scripts/validate_project.mjs",
    "validate:sources": "node scripts/validate_project.mjs --with-sources",
    "validate:continuity": "node scripts/validate_project.mjs --with-sources --with-continuity",
    "validate:strict": "node scripts/validate_project.mjs --strict-assets",
    "validate:sources:strict": "node scripts/validate_project.mjs --with-sources --strict-assets",
    "validate:production": "node scripts/validate_project.mjs --with-sources --with-continuity --strict-assets",
    "probe": "node scripts/run_media_tool.mjs ffprobe -v error -show_streams -show_format out/final.mp4",
    "frame:check": "node scripts/run_media_tool.mjs ffmpeg -y -ss 5 -i out/final.mp4 -frames:v 1 out/check-05.png"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0"
  }
}
